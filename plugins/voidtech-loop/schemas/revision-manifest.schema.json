{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "voidtech-loop committed bundle manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "decision_id", "approval_bundle_hash", "files"],
  "properties": {
    "schema_version": { "const": 1 },
    "kind": { "enum": ["revision", "supplemental_verification"] },
    "decision_id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "approval_bundle_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "sha256"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
