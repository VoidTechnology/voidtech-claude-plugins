{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Goal Spec v1",
  "description": "voidtech-loop 不可变 Goal Spec。唯一字段规则来源：skill、启动 gate 与控制器都经 scripts/goal-spec 使用本文件，禁止复制字段清单。",
  "type": "object",
  "required": ["schema_version", "goal_id", "task", "base_commit", "budgets", "evals"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "goal_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
    "task": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "base_commit": { "type": "string", "pattern": "^[0-9a-fA-F]{7,40}$" },
    "budgets": {
      "type": "object",
      "required": ["max_iterations"],
      "additionalProperties": false,
      "properties": {
        "max_iterations": { "type": "integer", "minimum": 1, "maximum": 200 },
        "max_duration_seconds": { "type": "integer", "minimum": 60, "maximum": 86400 }
      }
    },
    "setup": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "protected_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "pattern": "^[^!]" }
    },
    "evals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "role", "command", "timeout_seconds"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
          "role": { "enum": ["target", "invariant"] },
          "command": {
            "anyOf": [
              { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
              { "type": "string", "minLength": 1 }
            ]
          },
          "shell": { "type": "boolean" },
          "cwd": { "type": "string", "minLength": 1 },
          "expected_exit": { "type": "integer", "minimum": 0, "maximum": 255 },
          "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 7200 },
          "repeat": { "type": "integer", "minimum": 1, "maximum": 10 }
        }
      }
    },
    "manual_review": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
