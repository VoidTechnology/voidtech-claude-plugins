{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "voidtech-loop delegation grant v1",
  "description": "有界委托的一次性授权（二期技术设计 §5.2）。Phase 2 只支持 exact plan policy；may_weaken_invariants / may_change_out_of_scope 恒为 false；one_shot 恒为 true；allowed_plan_hashes 只接受精确 hash，不支持程序名、前缀、正则或通配符。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "grant_id", "run_id", "issued_at", "scope", "execution", "limits", "expires_at", "one_shot", "issued_by"],
  "properties": {
    "schema_version": { "const": 1 },
    "grant_id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "run_id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "issued_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T" },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcomes", "existing_fields", "append_eval_max", "append_agent_review_max", "may_weaken_invariants", "may_change_out_of_scope"],
      "properties": {
        "outcomes": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["accept", "revise"] }
        },
        "existing_fields": { "const": "byte_identical" },
        "append_eval_max": { "type": "integer", "minimum": 0, "maximum": 10 },
        "append_agent_review_max": { "type": "integer", "minimum": 0, "maximum": 10 },
        "may_weaken_invariants": { "const": false },
        "may_change_out_of_scope": { "const": false }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "inherit_parent_plans", "allowed_plan_hashes"],
      "properties": {
        "policy": { "const": "exact" },
        "inherit_parent_plans": { "type": "boolean" },
        "allowed_plan_hashes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_commands", "max_total_seconds", "network"],
      "properties": {
        "max_commands": { "type": "integer", "minimum": 1, "maximum": 64 },
        "max_total_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "network": { "enum": ["denied", "best_effort_not_denied"] }
      }
    },
    "expires_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T" },
    "one_shot": { "const": true },
    "issued_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "claimed_id", "identity_verified"],
      "properties": {
        "kind": { "const": "local_user" },
        "claimed_id": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
        "identity_verified": { "type": "boolean" }
      }
    }
  }
}
